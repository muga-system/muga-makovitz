---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { siteConfig } from "../data/site";
import { buildWhatsAppUrl } from "../utils/whatsapp";

const footerWhatsappUrl = buildWhatsAppUrl(
  siteConfig.whatsappNumber,
  "Hola! Quiero consultar mi checkout en Nora Makovitz."
);
---

<BaseLayout
  title={`Checkout | ${siteConfig.brand}`}
  description="Completa tus datos y confirma tu pedido por WhatsApp."
  canonical={`${siteConfig.canonical}/checkout`}
  ogImage={siteConfig.seo.ogImage}
>
  <Navbar
    logoSrc={siteConfig.assets.logo}
    ctaUrl="/carrito"
    ctaLabel="Carrito"
    ctaType="cart"
    homeHref="/"
  />

  <main id="contenido" class="section">
    <div class="container checkout-grid grid-12">
      <section class="col-span-12 lg-col-span-7 checkout-form-wrap">
        <h1>Checkout</h1>
        <p class="section-subtitle">Completa tus datos y envia el pedido por WhatsApp.</p>
        <p class="checkout-note">Produccion limitada. Si un modelo esta bajo pedido, te lo confirmamos antes de cerrar.</p>

        <form id="checkout-form" class="checkout-form" data-phone={siteConfig.whatsappNumber}>
          <label>
            Nombre y apellido
            <input type="text" name="customerName" required minlength="3" />
          </label>

          <label>
            Telefono
            <input type="tel" name="customerPhone" required minlength="8" />
          </label>

          <label>
            Retiro
            <input type="text" value="Retiro coordinado" disabled />
          </label>

          <label>
            Notas (opcional)
            <textarea name="notes" rows="3" placeholder="Horario preferido, referencia, etc."></textarea>
          </label>

          <button class="btn btn-primary" type="submit">Confirmar pedido por WhatsApp</button>
        </form>
      </section>

      <aside class="col-span-12 lg-col-span-5 checkout-summary" id="checkout-summary">
        <h2>Resumen</h2>
        <div id="checkout-items"></div>
        <p class="checkout-total">Total: <strong id="checkout-total">$0</strong></p>
        <p class="checkout-note-small">Tiempo de entrega estimado: 3 a 7 dias habiles.</p>
      </aside>
    </div>
  </main>

  <SiteFooter
    brand={siteConfig.brand}
    instagram={siteConfig.instagram}
    instagramHandle={siteConfig.instagramHandle}
    whatsappUrl={footerWhatsappUrl}
  />

  <script>
    // @ts-nocheck
    import { getCart, getCartTotals } from "../store/cart";
    import { buildCheckoutMessage } from "../utils/checkoutToWhatsapp";
    import { formatArs } from "../utils/format";
    import { buildWhatsAppUrl } from "../utils/whatsapp";

    const itemsNode = document.getElementById("checkout-items");
    const totalNode = document.getElementById("checkout-total");
    const summaryNode = document.getElementById("checkout-summary");
    const form = document.getElementById("checkout-form");
    const navButton = document.querySelector("[data-cart-button]");

    const renderCartCount = () => {
      const badge = document.querySelector("[data-cart-count]");
      if (!navButton) return;
      const totals = getCartTotals();
      navButton.classList.toggle("is-full", totals.count > 0);
      navButton.setAttribute("aria-label", totals.count > 0 ? `Carrito con ${totals.count} productos` : "Carrito vacio");
      if (badge) {
        badge.textContent = String(totals.count);
        badge.hidden = totals.count === 0;
      }
    };

    const items = getCart();
    if (!items.length) {
      summaryNode.innerHTML = '<h2>Resumen</h2><p class="cart-empty">No hay productos en carrito. <a href="/tienda">Ir a tienda</a></p>';
    } else {
      itemsNode.innerHTML = items
        .map(
          (item) =>
            `<div class="checkout-item"><span>${item.qty}x ${item.name}</span><strong>${formatArs(item.qty * item.price)}</strong></div>`
        )
        .join("");
      totalNode.textContent = formatArs(getCartTotals().total);
    }

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const payload = new FormData(form);
      const customerName = String(payload.get("customerName") || "").trim();
      const customerPhone = String(payload.get("customerPhone") || "").trim();
      const notes = String(payload.get("notes") || "").trim();

      if (!customerName || !customerPhone) return;
      const cart = getCart();
      if (!cart.length) return;

      const message = buildCheckoutMessage({
        customerName,
        customerPhone,
        notes,
        items: cart
      });

      const url = buildWhatsAppUrl(form.dataset.phone, message);
      window.location.href = url;
    });

    renderCartCount();
  </script>
</BaseLayout>
