---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getProductBySlug, products } from "../../data/products";
import { siteConfig } from "../../data/site";
import { formatArs } from "../../utils/format";
import { buildWhatsAppUrl } from "../../utils/whatsapp";

export const getStaticPaths = () =>
  products.filter((product) => product.active).map((product) => ({ params: { slug: product.slug } }));

const slug = Astro.params.slug || "";
const product = getProductBySlug(slug);

const detailImages = (() => {
  const base = product?.images?.length ? [...product.images] : [siteConfig.assets.heroImage];
  while (base.length < 4) {
    base.push(base[0]);
  }
  return base.slice(0, 4);
})();

const footerWhatsappUrl = buildWhatsAppUrl(
  siteConfig.whatsappNumber,
  `Hola! Quiero consultar ${product?.name || "una pieza"} de Nora Makovitz.`
);

const getStockLabel = (stock: number): string => {
  if (stock <= 0) return "Sin stock";
  if (stock <= 2) return `Ultimas unidades (${stock})`;
  return `Disponible (${stock})`;
};

if (!product) {
  return Astro.redirect("/tienda");
}
---

<BaseLayout
  title={`${product.name} | ${siteConfig.brand}`}
  description={product.description}
  canonical={`${siteConfig.canonical}/producto/${product.slug}`}
  ogImage={product.images[0] || siteConfig.seo.ogImage}
>
  <Navbar
    ctaUrl="/carrito"
    ctaLabel="Carrito"
    ctaType="cart"
    homeHref="/"
  />

  <main id="contenido" class="section">
    <div class="container product-detail grid-12">
      <figure class="col-span-12 lg-col-span-6 detail-image-wrap">
        <div class="detail-media">
          <img
            class="detail-image"
            id="detail-main-image"
            src={detailImages[0]}
            alt={product.name}
            loading="eager"
            decoding="async"
          />

          <div class="detail-thumbs" aria-label="Galeria de producto">
            {
              detailImages.map((img, index) => (
                <button
                  type="button"
                  class={`thumb-button ${index === 0 ? "is-active" : ""}`}
                  data-image={img}
                  aria-label={`Ver imagen ${index + 1}`}
                >
                  <img src={img} alt={`${product.name} vista ${index + 1}`} loading="lazy" decoding="async" />
                </button>
              ))
            }
          </div>
        </div>
      </figure>

      <section class="col-span-12 lg-col-span-6 detail-content">
        <p class="detail-kicker">Hecho a mano</p>
        <h1>{product.name}</h1>
        <p class="detail-price">{formatArs(product.price)}</p>
        <p class={`stock ${product.stock > 0 ? "stock-ok" : "stock-out"}`}>{getStockLabel(product.stock)}</p>
        <p class="detail-description">{product.description}</p>

        <section class="detail-block" aria-label="Uso recomendado">
          <h2>Uso</h2>
          <p>{product.use}</p>
        </section>

        <section class="detail-block" aria-label="Caracteristicas">
          <h2>Caracteristicas</h2>
          <ul class="detail-features">
            {product.features.map((feature) => <li>{feature}</li>)}
          </ul>
        </section>

        <p class="detail-close">{product.close}</p>

        <div class="detail-actions">
          <button
            type="button"
            class="btn btn-primary"
            id="add-detail-cart"
            data-id={product.id}
            data-slug={product.slug}
            data-name={product.name}
            data-price={product.price}
            data-stock={product.stock}
            data-image={product.images[0]}
            disabled={product.stock === 0}
          >
            <i data-lucide="shopping-cart" class="btn-icon" aria-hidden="true"></i>
            <span>Agregar</span>
          </button>
          <a class="btn btn-primary" href="/checkout">Comprar ahora</a>
          <button type="button" class="btn btn-secondary" id="add-detail-favorite" data-id={product.id}>
            Guardar
          </button>
          <a class="btn btn-secondary" href="/tienda">Volver a tienda</a>
        </div>
      </section>
    </div>
  </main>

  <SiteFooter
    brand={siteConfig.brand}
    instagram={siteConfig.instagram}
    instagramHandle={siteConfig.instagramHandle}
    whatsappUrl={footerWhatsappUrl}
  />

  <script>
    // @ts-nocheck
    import { cartStore } from "../../store/cart";
    import { toggleFavorite, isFavorite } from "../../store/favorites";

    const addCart = document.getElementById("add-detail-cart");
    const addFav = document.getElementById("add-detail-favorite");
    const navButton = document.querySelector("[data-cart-button]");
    const mainImage = document.getElementById("detail-main-image");
    const thumbButtons = document.querySelectorAll(".thumb-button");

    const renderCartCount = () => {
      const badge = document.querySelector("[data-cart-count]");
      if (!navButton) return;
      const count = cartStore.getState().getCount();
      navButton.classList.toggle("is-full", count > 0);
      navButton.setAttribute("aria-label", count > 0 ? `Carrito con ${count} productos` : "Carrito vacío");
      if (badge) {
        badge.textContent = String(count);
        badge.hidden = count === 0;
      }
    };

    cartStore.subscribe(renderCartCount);

    if (addCart) {
      addCart.addEventListener("click", () => {
        const stock = Number(addCart.dataset.stock || "0");
        if (stock <= 0) return;
        cartStore.getState().addItem(
          {
            id: addCart.dataset.id,
            slug: addCart.dataset.slug,
            name: addCart.dataset.name,
            price: Number(addCart.dataset.price),
            stock,
            image: addCart.dataset.image
          },
          1
        );
        renderCartCount();
        showToast("Agregado al carrito", "success", "cart");
        const label = addCart.querySelector("span:last-child");
        if (label) label.textContent = "Agregado";
      });
    }

    if (addFav) {
      if (isFavorite(addFav.dataset.id)) {
        addFav.textContent = "Guardado";
      }
      addFav.addEventListener("click", () => {
        const isFav = toggleFavorite(addFav.dataset.id);
        showToast(isFav.includes(addFav.dataset.id) ? "Guardado en favoritos" : "Eliminado de favoritos", "success", "heart");
        addFav.textContent = isFavorite(addFav.dataset.id) ? "Guardado" : "Guardar";
      });
    }

    thumbButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!mainImage) return;
        mainImage.src = button.dataset.image;
        thumbButtons.forEach((thumb) => thumb.classList.remove("is-active"));
        button.classList.add("is-active");
      });
    });

    renderCartCount();
  </script>
</BaseLayout>
