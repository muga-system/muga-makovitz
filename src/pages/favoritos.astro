---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { products } from "../data/products";
import { siteConfig } from "../data/site";
import { formatArs } from "../utils/format";
import { buildWhatsAppUrl } from "../utils/whatsapp";

const activeProducts = products.filter((product) => product.active);
const footerWhatsappUrl = buildWhatsAppUrl(
  siteConfig.whatsappNumber,
  "Hola! Quiero consultar mis favoritos de Nora Makovitz."
);

const getStockLabel = (stock: number): string => {
  if (stock <= 0) return "Sin stock";
  if (stock <= 2) return `Ultimas unidades (${stock})`;
  return `Disponible (${stock})`;
};
---

<BaseLayout
  title={`Favoritos | ${siteConfig.brand}`}
  description="Tus piezas guardadas para comprar despues."
  canonical={`${siteConfig.canonical}/favoritos`}
  ogImage={siteConfig.seo.ogImage}
>
  <Navbar
    logoSrc={siteConfig.assets.logo}
    ctaUrl="/carrito"
    ctaLabel="Carrito"
    ctaType="cart"
    homeHref="/"
  />

  <main id="contenido" class="section">
    <div class="container">
      <p class="section-kicker">Favoritos</p>
      <h1>Favoritos</h1>
      <p class="section-subtitle">Modelos guardados para decidir con calma.</p>

      <div id="favorites-empty" class="cart-empty" hidden>
        Aun no guardaste favoritos. <a href="/tienda">Ir a tienda</a>
      </div>

      <div class="grid-12 cards-grid" id="favorites-grid">
        {
          activeProducts.map((item) => (
            <article class="col-span-12 sm-col-span-6 lg-col-span-3 shop-product" data-id={item.id}>
              <a class="shop-image-link" href={`/producto/${item.slug}`}>
                <img class="card-image card-image-product" src={item.images[0]} alt={item.name} loading="lazy" decoding="async" />
              </a>
              <h2 class="card-title">{item.name}</h2>
              <p class="card-meta">{item.cardBenefit}</p>
              <p class="card-price">{formatArs(item.price)}</p>
              <p class={`stock ${item.stock > 0 ? "stock-ok" : "stock-out"}`}>{getStockLabel(item.stock)}</p>
              <div class="shop-actions">
                <button
                  type="button"
                  class="btn btn-primary add-cart"
                  data-id={item.id}
                  data-slug={item.slug}
                  data-name={item.name}
                  data-price={item.price}
                  data-stock={item.stock}
                  data-image={item.images[0]}
                  disabled={item.stock === 0}
                >
                  <i data-lucide="shopping-cart" class="btn-icon" aria-hidden="true"></i>
                  <span>Agregar</span>
                </button>
                <button type="button" class="btn btn-secondary remove-favorite" data-id={item.id}>Quitar</button>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </main>

  <SiteFooter
    brand={siteConfig.brand}
    instagram={siteConfig.instagram}
    instagramHandle={siteConfig.instagramHandle}
    whatsappUrl={footerWhatsappUrl}
  />

  <script>
    // @ts-nocheck
    import { cartCount, addToCart } from "../store/cart";
    import { toggleFavorite, isFavorite, getFavorites, removeFavorite, favoriteIds } from "../store/favorites";

    const initFavoritesPage = () => {
      if (!window.location.pathname.startsWith("/favoritos")) return;

      const cards = Array.from(document.querySelectorAll(".shop-product"));
      const empty = document.getElementById("favorites-empty");
      const grid = document.getElementById("favorites-grid");
      const navButton = document.querySelector("[data-cart-button]");

      const renderCartCount = () => {
        const badge = document.querySelector("[data-cart-count]");
        if (!navButton) return;
        const count = cartCount.get();
        navButton.classList.toggle("is-full", count > 0);
        navButton.classList.toggle("btn-primary", count > 0);
        navButton.classList.toggle("btn-secondary", count === 0);
        navButton.setAttribute("aria-label", count > 0 ? `Carrito con ${count} productos` : "Carrito vacío");
        if (badge) {
          badge.textContent = String(count);
          badge.hidden = count === 0;
        }
      };

      const renderFavoritesBadge = () => {
        const favButton = document.querySelector("[data-favorites-button]");
        const badge = document.querySelector("[data-favorites-count]");
        if (!favButton) return;
        const count = favoriteIds.get().length;
        favButton.classList.toggle("is-full", count > 0);
        favButton.classList.toggle("btn-primary", count > 0);
        favButton.classList.toggle("btn-secondary", count === 0);
      };

      cartCount.subscribe(renderCartCount);
      favoriteIds.subscribe(renderFavoritesBadge);

      const applyVisibility = () => {
        const favorites = new Set(getFavorites());
        let visible = 0;
        cards.forEach((card) => {
          const show = favorites.has(card.dataset.id);
          card.style.display = show ? "grid" : "none";
          if (show) visible += 1;
        });
        if (empty) empty.hidden = visible !== 0;
        if (grid) grid.classList.toggle("is-single-result", visible === 1);
      };

      if (!grid?.dataset.bound) {
        grid.dataset.bound = "true";
        grid.addEventListener("click", (event) => {
          const cartBtn = event.target.closest(".add-cart");
          if (cartBtn) {
            const stock = Number(cartBtn.dataset.stock || "0");
            if (stock <= 0) return;
            addToCart(
              {
                id: cartBtn.dataset.id,
                slug: cartBtn.dataset.slug,
                name: cartBtn.dataset.name,
                price: Number(cartBtn.dataset.price),
                stock,
                image: cartBtn.dataset.image
              },
              1
            );
            showToast("Agregado al carrito", "success", "cart");
            const label = cartBtn.querySelector("span:last-child");
            if (label) label.textContent = "Agregado";
            return;
          }

          const removeBtn = event.target.closest(".remove-favorite");
          if (!removeBtn) return;
          removeFavorite(removeBtn.dataset.id);
          showToast("Eliminado de favoritos", "success", "heart");
          applyVisibility();
        });
      }

      applyVisibility();
      renderCartCount();
    };

    initFavoritesPage();
    document.addEventListener("astro:page-load", initFavoritesPage);
  </script>
</BaseLayout>
