---
type Props = {
  ctaUrl: string;
  ctaLabel: string;
  homeHref?: string;
  ctaType?: "default" | "cart";
};

const { ctaUrl, ctaLabel, homeHref = "/", ctaType = "default" } = Astro.props;
---

<nav class="top-nav" aria-label="Navegacion principal">
  <div class="container top-nav-grid">
    <a class="brand-link" href={homeHref} aria-label="Ir al inicio">
      NM
    </a>

    <div class="nav-actions">
      <a
        href="/favoritos"
        class="btn btn-secondary nav-favorites"
        data-favorites-button
        aria-label="Favoritos"
      >
        <i data-lucide="heart-plus" class="fav-icon"></i>
        <span class="favorites-count" data-favorites-count hidden>0</span>
      </a>
      {
        ctaType === "cart" ? (
        <a
          class="btn btn-secondary nav-cart"
          href={ctaUrl}
          data-track="click_whatsapp_primary"
          data-label="Nav Cart"
          data-cart-button
          aria-label="Carrito vacio"
        >
          <i data-lucide="shopping-cart" class="cart-icon cart-icon-empty" aria-hidden="true"></i>
          <i data-lucide="baggage-claim" class="cart-icon cart-icon-full" aria-hidden="true"></i>
          <span class="cart-count" data-cart-count hidden>0</span>
        </a>
      ) : (
        <a class="btn btn-primary" href={ctaUrl} data-track="click_whatsapp_primary" data-label="Nav CTA">
          {ctaLabel}
        </a>
      )
      }
      <a
        href="/tienda"
        class="btn btn-primary nav-tienda"
      >
        <i data-lucide="store"></i>
        <span class="tienda-label">Tienda</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .top-nav-grid {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: var(--header-height);
    gap: 0.5rem;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--primary);
    color: #fff;
    font-weight: 700;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .nav-actions {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .nav-actions a,
  .nav-actions button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0;
  }

  .nav-favorites,
  .nav-cart {
    width: 44px;
    position: relative;
  }

  .nav-favorites i,
  .nav-cart i {
    width: 20px;
    height: 20px;
  }

  .nav-tienda {
    padding: 0 0.875rem;
    gap: 0.375rem;
  }

  .nav-tienda i {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 480px) {
    .tienda-label {
      display: none;
    }

    .nav-tienda {
      width: 44px;
      padding: 0;
    }
  }
</style>
