---
type Props = {
  items: { quote: string; author: string }[];
};

const { items } = Astro.props;
---

<section class="section section-soft" id="testimonios" aria-labelledby="testimonios-title">
  <div class="container">
    <h2 id="testimonios-title">Lo que dicen quienes ya eligieron Nora Makovitz</h2>
    <div class="testimonials-grid">
      {
        items.map((item) => (
          <figure class="testimonial">
            <blockquote>{item.quote}</blockquote>
            <figcaption>{item.author}</figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
