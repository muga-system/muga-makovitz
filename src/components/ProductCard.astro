---
type Props = {
  item: {
    name: string;
    description: string;
    priceRange: string;
    badge: string;
    slug: string;
  };
  whatsappUrl: string;
};

const { item, whatsappUrl } = Astro.props;
---

<article class="product-card" aria-label={item.name}>
  <span class="badge">{item.badge}</span>
  <h3>{item.name}</h3>
  <p>{item.description}</p>
  <p class="price">{item.priceRange}</p>

  <a
    class="btn btn-outline"
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    data-track={`click_whatsapp_product_${item.slug}`}
    data-label={item.name}
  >
    Consultar por WhatsApp
  </a>
</article>
