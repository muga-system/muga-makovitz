---
type Props = {
  brand: string;
  instagram: string;
  instagramHandle: string;
  whatsappUrl: string;
};

const { brand, instagram, instagramHandle, whatsappUrl } = Astro.props;
---

<footer class="site-footer">
  <div class="container site-footer-inner">
    <div class="site-footer-top">
      <p class="site-footer-brand">{brand}</p>
      <nav class="site-footer-nav" aria-label="Footer">
        <a href="/tienda">Tienda</a>
        <a href="/favoritos">Favoritos</a>
        <a href="/carrito">Carrito</a>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer">WhatsApp</a>
        <a href={instagram} target="_blank" rel="noopener noreferrer">Instagram {instagramHandle}</a>
      </nav>
    </div>

    <p class="site-footer-version">
      v1.0 -
      <a href="https://muga.dev" target="_blank" rel="noopener noreferrer">muga.dev</a>
    </p>
  </div>
</footer>
