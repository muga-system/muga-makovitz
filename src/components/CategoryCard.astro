---
import type { CategoryItem } from "../data/site";

type Props = {
  item: CategoryItem;
  ctaUrl: string;
};

const { item, ctaUrl } = Astro.props;

const iconByCategory: Record<string, string> = {
  carteras: "shopping-bag",
  bolsos: "briefcase",
  organizadores: "package",
  regalos: "gift"
};

const categoryIcon = iconByCategory[item.slug] || "shopping-bag";
---

<article class="layout-card category-card" aria-label={item.name}>
  <span class="category-icon" aria-hidden="true">
    <i data-lucide={categoryIcon}></i>
  </span>
  <h3 class="card-title">{item.name}</h3>
  <p class="card-meta">{item.meta}</p>
  <a class="btn btn-secondary card-cta" href={ctaUrl} data-track="click_whatsapp_secondary" data-label={`Category ${item.slug}`}>
    <i data-lucide="eye" class="btn-icon" aria-hidden="true"></i>
    Ver
  </a>
</article>
