---
type Props = {
  whatsappUrl: string;
};

const { whatsappUrl } = Astro.props;
---

<section class="section cta-final" aria-labelledby="cta-final-title">
  <div class="container cta-box">
    <h2 id="cta-final-title">Queres que te ayude a elegir la pieza ideal?</h2>
    <p>
      Escribime por WhatsApp y te comparto opciones segun uso, presupuesto y disponibilidad real.
    </p>
    <a
      class="btn btn-primary"
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      data-track="click_whatsapp_primary"
      data-label="CTA final"
    >
      Hablar por WhatsApp
    </a>
  </div>
</section>
