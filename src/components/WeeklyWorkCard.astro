---
import type { WeeklyWork } from "../data/site";

type Props = {
  item: WeeklyWork;
  ctaUrl: string;
};

const { item, ctaUrl } = Astro.props;
---

<article class="layout-card weekly-card" aria-label={item.title}>
  <img class="card-image" src={item.image} alt={item.title} loading="lazy" decoding="async" />
  <h3 class="card-title">{item.title}</h3>
  <p class="card-meta">{item.note}</p>
  <a class="btn btn-secondary card-cta" href={ctaUrl} data-track="click_whatsapp_secondary" data-label={item.title}>
    Consultar
  </a>
</article>
